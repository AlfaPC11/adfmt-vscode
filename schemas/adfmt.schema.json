{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alfa.dev/schemas/adfmt.schema.json",
  "$comment": "SPDX-License-Identifier: BSD-3-Clause AND LicenseRef-Alfa-Patent-Grant",
  "title": "Alfa's D Formatter configuration",
  "description": "Configuration for adfmt. The file name is .adfmt and its syntax is YAML.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "BasedOnStyle": {
      "type": "string",
      "enum": [
        "Alfa",
        "Dfmt",
        "Allman",
        "Knr",
        "Stroustrup",
        "Otbs",
        "Linux",
        "Compact"
      ],
      "description": "Base style used before applying the remaining options."
    },
    "DisableFormat": {
      "type": "boolean",
      "default": false,
      "description": "Return source text unchanged when enabled."
    },
    "ColumnLimit": {
      "$ref": "#/$defs/positiveInteger"
    },
    "SoftColumnLimit": {
      "$ref": "#/$defs/positiveInteger"
    },
    "LineEnding": {
      "type": "string",
      "enum": [
        "Default",
        "Lf",
        "Cr",
        "Crlf"
      ]
    },
    "Indent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "Width": {
          "$ref": "#/$defs/positiveInteger"
        },
        "ContinuationWidth": {
          "$ref": "#/$defs/positiveInteger"
        },
        "TabWidth": {
          "$ref": "#/$defs/positiveInteger"
        },
        "Style": {
          "type": "string",
          "enum": [
            "Space",
            "Tab"
          ]
        },
        "AlignSwitchStatements": {
          "type": "boolean"
        },
        "CaseLabels": {
          "type": "boolean"
        },
        "OutdentAttributes": {
          "type": "boolean"
        },
        "SingleContinuationIndent": {
          "type": "boolean"
        }
      }
    },
    "Braces": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "Default": {
          "$ref": "#/$defs/braceStyle"
        },
        "Declarations": {
          "$ref": "#/$defs/braceStyle"
        },
        "Aggregates": {
          "$ref": "#/$defs/braceStyle"
        },
        "Enums": {
          "$ref": "#/$defs/braceStyle"
        },
        "Functions": {
          "$ref": "#/$defs/braceStyle"
        },
        "FunctionLiterals": {
          "$ref": "#/$defs/braceStyle"
        },
        "ControlStatements": {
          "$ref": "#/$defs/braceStyle"
        }
      }
    },
    "Spacing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "AfterCast": {
          "type": "boolean"
        },
        "AfterKeywords": {
          "type": "boolean"
        },
        "BeforeFunctionParameters": {
          "type": "boolean"
        },
        "SelectiveImports": {
          "type": "boolean"
        },
        "BeforeAssociativeArrayColon": {
          "type": "boolean"
        },
        "BeforeNamedArgumentColon": {
          "type": "boolean"
        },
        "BeforeBraces": {
          "type": "boolean"
        },
        "AroundBinaryOperators": {
          "type": "boolean"
        }
      }
    },
    "Wrapping": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "KeepExistingLineBreaks": {
          "type": "boolean"
        },
        "SplitOperatorAtLineEnd": {
          "type": "boolean"
        },
        "BinaryOperators": {
          "type": "string",
          "enum": [
            "Before",
            "After"
          ]
        },
        "ReflowPropertyChains": {
          "type": "boolean"
        },
        "TemplateConstraints": {
          "$ref": "#/$defs/templateConstraintStyle"
        },
        "SingleTemplateConstraintIndent": {
          "type": "boolean"
        },
        "NewlinePenalty": {
          "$ref": "#/$defs/positiveInteger"
        },
        "LongLinePenalty": {
          "$ref": "#/$defs/positiveInteger"
        }
      }
    },
    "Statements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "CompactLabels": {
          "type": "boolean"
        }
      }
    },
    "IndentWidth": {
      "$ref": "#/$defs/positiveInteger"
    },
    "ContinuationIndentWidth": {
      "$ref": "#/$defs/positiveInteger"
    },
    "TabWidth": {
      "$ref": "#/$defs/positiveInteger"
    },
    "UseTab": {
      "type": "string",
      "enum": [
        "Space",
        "Tab"
      ]
    },
    "AlignSwitchStatements": {
      "type": "boolean"
    },
    "IndentCaseLabels": {
      "type": "boolean"
    },
    "OutdentAttributes": {
      "type": "boolean"
    },
    "SingleIndent": {
      "type": "boolean"
    },
    "BraceStyle": {
      "$ref": "#/$defs/braceStyle"
    },
    "DeclarationBraceStyle": {
      "$ref": "#/$defs/braceStyle"
    },
    "AggregateBraceStyle": {
      "$ref": "#/$defs/braceStyle"
    },
    "EnumBraceStyle": {
      "$ref": "#/$defs/braceStyle"
    },
    "FunctionBraceStyle": {
      "$ref": "#/$defs/braceStyle"
    },
    "FunctionLiteralBraceStyle": {
      "$ref": "#/$defs/braceStyle"
    },
    "ControlBraceStyle": {
      "$ref": "#/$defs/braceStyle"
    },
    "SpaceAfterCast": {
      "type": "boolean"
    },
    "SpaceAfterKeywords": {
      "type": "boolean"
    },
    "SpaceBeforeFunctionParameters": {
      "type": "boolean"
    },
    "SelectiveImportSpace": {
      "type": "boolean"
    },
    "SpaceBeforeAssociativeArrayColon": {
      "type": "boolean"
    },
    "SpaceBeforeNamedArgumentColon": {
      "type": "boolean"
    },
    "SpaceBeforeBraces": {
      "type": "boolean"
    },
    "SpaceAroundBinaryOperators": {
      "type": "boolean"
    },
    "KeepLineBreaks": {
      "type": "boolean"
    },
    "SplitOperatorAtLineEnd": {
      "type": "boolean"
    },
    "BinaryOperatorBreakStyle": {
      "type": "string",
      "enum": [
        "Before",
        "After"
      ]
    },
    "ReflowPropertyChains": {
      "type": "boolean"
    },
    "TemplateConstraintStyle": {
      "$ref": "#/$defs/templateConstraintStyle"
    },
    "SingleTemplateConstraintIndent": {
      "type": "boolean"
    },
    "WrappingNewlinePenalty": {
      "$ref": "#/$defs/positiveInteger"
    },
    "WrappingLongLinePenalty": {
      "$ref": "#/$defs/positiveInteger"
    },
    "CompactLabeledStatements": {
      "type": "boolean"
    }
  },
  "$defs": {
    "positiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "braceStyle": {
      "type": "string",
      "enum": [
        "Allman",
        "Otbs",
        "Stroustrup",
        "Knr"
      ]
    },
    "templateConstraintStyle": {
      "type": "string",
      "enum": [
        "ConditionalNewlineIndent",
        "ConditionalNewline",
        "AlwaysNewline",
        "AlwaysNewlineIndent"
      ]
    }
  }
}
